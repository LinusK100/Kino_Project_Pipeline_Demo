# Lokale Konfiguration. Diese Datei nach ".env" kopieren — .env NICHT committen.
#
# Fuer den lokalen Betrieb sind KEINE Geheimnisse noetig (kein Server-Login,
# kein Registry-Token). Diese Datei ist daher optional.

# Port des Servers beim direkten "npm start" (Docker mappt 8080 -> 3000).
PORT=3000

# Nur relevant, wenn der optionale DB-Container in docker-compose.yml aktiviert wird:
# DB_PASSWORD=changeme
